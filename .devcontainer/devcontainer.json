{
  "name": "codex-devcontainer",

  // platform-harness-engineering の devcontainer に揃えたベース構成
  // vscode ユーザー（/home/vscode）、arm64 / amd64 両対応
  "image": "mcr.microsoft.com/devcontainers/python:3.12-bookworm",

  "features": {
    // Claude Code CLI
    "ghcr.io/anthropics/devcontainer-features/claude-code:1.0": {},

    // Node.js（Codex CLI のインストールに必要）
    "ghcr.io/devcontainers/features/node:2.0.0": {},

    // GitHub CLI（gh コマンド）: SDD フローで必須
    "ghcr.io/devcontainers/features/github-cli:1": {}

    // --- 以下はプロジェクトの技術スタックに応じて追加 ---

    // AWS CLI（AWS プロジェクトの場合）
    // "ghcr.io/devcontainers/features/aws-cli:1": {},

    // Docker-in-Docker（コンテナビルドが必要な場合）
    // "ghcr.io/devcontainers/features/docker-in-docker:3.0.1": {}
  },

  "postCreateCommand": "bash .devcontainer/postCreate.sh",

  "mounts": [
    // Codex CLI の個人設定・認証情報を引き継ぐ
    "source=${localEnv:HOME}/.codex,target=/home/vscode/.codex,type=bind,consistency=cached",

    // Claude Code 設定・認証情報を引き継ぐ
    "source=${localEnv:HOME}/.claude,target=/home/vscode/.claude,type=bind,consistency=cached",

    // GitHub CLI 認証情報を引き継ぐ
    "source=${localEnv:HOME}/.config/gh,target=/home/vscode/.config/gh,type=bind,consistency=cached"

    // --- 以下はプロジェクトの要件に応じて追加 ---

    // AWS 認証情報（AWS プロジェクトの場合）
    // "source=${localEnv:HOME}/.aws,target=/home/vscode/.aws,type=bind,consistency=cached"
  ],

  "containerEnv": {
    // プロジェクト固有の環境変数をここに追加
    // 例: "AWS_PROFILE": "your-profile"
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "tamasfe.even-better-toml"
        // 例（TypeScript）: "dbaeumer.vscode-eslint", "esbenp.prettier-vscode"
      ],

      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "python.terminal.activateEnvironment": true
      }
    }
  }
}
